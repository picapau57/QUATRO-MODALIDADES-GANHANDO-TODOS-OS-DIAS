{
  "version": 2,
  "builds": [
    {
      "src": "dist/server.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/server.cjs"
    },
    {
      "src": "/assets/(.*)",
      "dest": "dist/assets/$1"
    },
    {
      "src": "/icon.svg",
      "dest": "dist/icon.svg"
    },
    {
      "src": "/manifest.json",
      "dest": "dist/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "dist/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "dist/index.html"
    }
  ]
}
